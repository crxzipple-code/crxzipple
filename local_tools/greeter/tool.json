{
  "id": "greeter",
  "name": "Greeter",
  "description": "Greet a person through a filesystem-discovered local tool.",
  "kind": "function",
  "entrypoint": "handler.py:run",
  "parameters": [
    {
      "name": "name",
      "data_type": "string",
      "description": "Person to greet.",
      "required": true
    }
  ],
  "tags": ["local", "filesystem", "greeting"],
  "timeout_seconds": 30,
  "supported_modes": ["inline", "background"],
  "supported_strategies": ["async", "thread", "process"],
  "supported_environments": ["local"],
  "enabled": true
}
