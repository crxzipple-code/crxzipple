# CRXZipple local development environment.
# Copy to .env for personal overrides. Never commit .env.

CRXZIPPLE_POSTGRES_DB=crxzipple
CRXZIPPLE_POSTGRES_USER=crxzipple
CRXZIPPLE_POSTGRES_PASSWORD=change-me-local-only
CRXZIPPLE_POSTGRES_PORT=5432

CRXZIPPLE_REDIS_PORT=6379

APP_DATABASE_URL=postgresql+psycopg://crxzipple:change-me-local-only@127.0.0.1:5432/crxzipple
APP_EVENTS_BACKEND=redis
APP_EVENTS_REDIS_URL=redis://127.0.0.1:6379/0

# Optional provider credentials.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# Optional channel credentials.
LARK_APP_ID=
LARK_APP_SECRET=
LARK_VERIFICATION_TOKEN=
LARK_ENCRYPT_KEY=
